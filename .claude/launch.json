{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "widget-prod-preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@tmw/server", "exec", "tsx", "scripts/preview.ts"],
      "autoPort": true,
      "port": 3100
    },
    {
      "name": "web-dev",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@tmw/web", "dev"],
      "port": 5173
    },
    {
      "name": "web-preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@tmw/web", "exec", "vite", "--port", "5199", "--strictPort"],
      "port": 5199
    },
    {
      "name": "overlay-preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@tmw/overlay", "exec", "vite", "--port", "5198", "--strictPort"],
      "port": 5198
    }
  ]
}
